# Strata - Environment Configuration
# Copy this file to .env and update values as needed

# SurrealDB Configuration
SURREALDB_URL=http://127.0.0.1:8000/sql
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=strata
SURREALDB_DB=strata

# Server Ports
ROUTER_PORT=8080
PLANNER_PORT=8081
CONTROL_PLANE_PORT=8082

# Other Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2